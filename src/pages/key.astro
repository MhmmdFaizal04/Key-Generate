---
import Layout from "../layouts/Layout.astro";
import { query } from "../lib/db";

export const prerender = false;

// 1. Get the session token
const pendingToken = Astro.cookies.get("pending_access_token")?.value;

if (!pendingToken) {
    return Astro.redirect("/generate");
}

let keyData = null;
let errorMsg = null;
let tokenRecordId = null;

try {
    // 2. Validate token (exists, not used, not expired - 30 mins)
    const tokenResult = await query(
        `
    SELECT id FROM access_tokens 
    WHERE token = $1 
      AND used = false 
      AND created_at > NOW() - INTERVAL '30 minutes'
  `,
        [pendingToken],
    );

    if (tokenResult.rows.length === 0) {
        // Missing, used, or expired
        Astro.cookies.delete("pending_access_token", { path: "/" });
        return Astro.redirect("/generate");
    }

    tokenRecordId = tokenResult.rows[0].id;

    // 3. Mark token as used instantly to prevent race conditions
    await query("UPDATE access_tokens SET used = true WHERE id = $1", [
        tokenRecordId,
    ]);

    // 4. Clear the generic cookie so it can't be reused even if DB update fails
    Astro.cookies.delete("pending_access_token", { path: "/" });

    // 5. Fetch one random available key
    const keyResult = await query(`
    SELECT * FROM keys 
    WHERE is_active = true 
      AND expires_at > NOW() 
    ORDER BY RANDOM() 
    LIMIT 1
  `);

    if (keyResult.rows.length > 0) {
        keyData = keyResult.rows[0];
    } else {
        errorMsg =
            "Saat ini tidak ada Key yang tersedia. Silakan hubungi Administrator sistem.";
    }
} catch (error) {
    console.error("Verification Error:", error);
    errorMsg = "Terjadi kesalahan pada server saat memverifikasi sesi.";
}
---

<Layout title="Akses Key Anda - Zall">
    <main class="key-container">
        <div class="glass-card key-card fade-in">
            {
                keyData ? (
                    <>
                        <div class="success-header mb-4">
                            <div class="success-icon slide-down">
                                <i class="bi bi-check-circle" />
                            </div>
                            <h1 class="page-title">Verifikasi Berhasil</h1>
                            <p class="text-muted text-sm">
                                Key akses 3 hari Anda telah siap digunakan.
                            </p>
                        </div>

                        <div class="credentials-box slide-up delay-1">
                            <div class="cred-row mb-3">
                                <span class="cred-label">Username</span>
                                <div class="cred-input-group">
                                    <input
                                        type="text"
                                        class="cred-input"
                                        id="keyUser"
                                        value={keyData.username}
                                        readonly
                                    />
                                    <button
                                        class="btn-copy"
                                        data-target="keyUser"
                                        title="Salin Username"
                                    >
                                        <i class="bi bi-clipboard" />
                                    </button>
                                </div>
                            </div>

                            <div class="cred-row mb-2">
                                <span class="cred-label">Password</span>
                                <div class="cred-input-group">
                                    <input
                                        type="text"
                                        class="cred-input text-accent"
                                        id="keyPass"
                                        value={keyData.password}
                                        readonly
                                    />
                                    <button
                                        class="btn-copy"
                                        data-target="keyPass"
                                        title="Salin Password"
                                    >
                                        <i class="bi bi-clipboard" />
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="action-footer mt-4 slide-up delay-2">
                            <div class="expiry-info">
                                <i class="bi bi-clock-history me-1" />
                                Berlaku hingga:{" "}
                                {new Date(
                                    keyData.expires_at,
                                ).toLocaleDateString("id-ID", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </div>

                            <button
                                class="btn-primary-elegant w-100 mt-4"
                                id="copyAllBtn"
                            >
                                <i class="bi bi-files me-2" /> Salin Semua
                                Kredensial
                            </button>
                        </div>
                    </>
                ) : (
                    <div class="error-state text-center py-4">
                        <div class="error-icon mb-3">
                            <i class="bi bi-exclamation-triangle" />
                        </div>
                        <h2 class="error-title">Key Habis</h2>
                        <p class="text-muted mb-4">{errorMsg}</p>
                        <a href="/generate" class="btn-secondary-elegant">
                            <i class="bi bi-arrow-left me-2" /> Kembali ke awal
                        </a>
                    </div>
                )
            }
        </div>
    </main>
</Layout>

<style>
    .key-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        z-index: 1;
        position: relative;
    }

    .key-card {
        width: 100%;
        max-width: 480px;
        padding: 48px 40px;
    }

    .success-header {
        text-align: center;
    }

    .success-icon {
        font-size: 3.5rem;
        color: var(--success);
        margin-bottom: 8px;
    }

    .page-title {
        font-size: 1.7rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--text-main);
        letter-spacing: -0.5px;
    }

    .text-muted {
        color: var(--text-muted);
    }

    .credentials-box {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 24px;
        margin-top: 24px;
    }

    .cred-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }

    .cred-input-group {
        display: flex;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.2s;
    }

    .cred-input-group:focus-within {
        border-color: var(--primary);
    }

    .cred-input {
        flex: 1;
        background: transparent;
        border: none;
        color: var(--text-main);
        padding: 14px 16px;
        font-family: "Courier New", Courier, monospace;
        font-size: 1.1rem;
        font-weight: 600;
        outline: none;
    }

    .text-accent {
        color: var(--accent);
    }

    .btn-copy {
        background: rgba(129, 140, 248, 0.1);
        border: none;
        color: var(--primary);
        padding: 0 16px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-copy:hover {
        background: var(--primary);
        color: white;
    }

    .expiry-info {
        text-align: center;
        font-size: 0.85rem;
        color: var(--warning);
        background: rgba(251, 191, 36, 0.1);
        padding: 10px;
        border-radius: 8px;
        border: 1px solid rgba(251, 191, 36, 0.2);
    }

    .btn-primary-elegant {
        background: var(--primary);
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-primary-elegant:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
    }

    .btn-secondary-elegant {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-main);
        border: 1px solid var(--card-border);
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

    .btn-secondary-elegant:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .error-icon {
        font-size: 3rem;
        color: var(--warning);
    }

    .error-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 8px;
    }

    .w-100 {
        width: 100%;
    }
    .mt-4 {
        margin-top: 1.5rem;
    }
    .mb-2 {
        margin-bottom: 0.5rem;
    }
    .mb-3 {
        margin-bottom: 1rem;
    }
    .mb-4 {
        margin-bottom: 1.5rem;
    }
    .me-1 {
        margin-right: 0.25rem;
    }
    .me-2 {
        margin-right: 0.5rem;
    }
    .py-4 {
        padding-top: 1.5rem;
        padding-bottom: 1.5rem;
    }

    /* Animations */
    .slide-down {
        animation: slideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .slide-up {
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    .delay-1 {
        animation-delay: 0.15s;
    }
    .delay-2 {
        animation-delay: 0.3s;
    }
    .fade-in {
        animation: fadeIn 0.5s ease;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px) scale(0.9);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
</style>

<script>
    // Copy Logic
    const copyButtons = document.querySelectorAll(".btn-copy");

    copyButtons.forEach((btn) => {
        btn.addEventListener("click", (e) => {
            const el = e.currentTarget as HTMLElement;
            const targetId = el.getAttribute("data-target");

            if (targetId) {
                const inputEl = document.getElementById(
                    targetId,
                ) as HTMLInputElement;
                if (inputEl) {
                    navigator.clipboard.writeText(inputEl.value);

                    const originalHtml = el.innerHTML;
                    el.innerHTML = '<i class="bi bi-check2"></i>';
                    el.style.background = "var(--success)";
                    el.style.color = "#fff";

                    setTimeout(() => {
                        el.innerHTML = originalHtml;
                        el.style.background = "";
                        el.style.color = "";
                    }, 1500);
                }
            }
        });
    });

    // Copy All
    const copyAllBtn = document.getElementById("copyAllBtn");
    if (copyAllBtn) {
        copyAllBtn.addEventListener("click", () => {
            const user =
                (document.getElementById("keyUser") as HTMLInputElement)
                    ?.value || "";
            const pass =
                (document.getElementById("keyPass") as HTMLInputElement)
                    ?.value || "";

            const text = `=== AKSES KEY ===\nUsername: ${user}\nPassword: ${pass}\n=================`;
            navigator.clipboard.writeText(text);

            const originalHtml = copyAllBtn.innerHTML;
            copyAllBtn.innerHTML =
                '<i class="bi bi-check-circle me-2"></i> Berhasil Disalin!';
            copyAllBtn.style.background = "var(--success)";

            setTimeout(() => {
                copyAllBtn.innerHTML = originalHtml;
                copyAllBtn.style.background = "";
            }, 2000);
        });
    }
</script>
