---
import Layout from "../layouts/Layout.astro";
import { query } from "../lib/db";

// Fetch active server links
let servers = [];
try {
    const result = await query(
        "SELECT id, server_name, label FROM redirect_links WHERE is_active = true ORDER BY id ASC",
    );
    servers = result.rows;
} catch (e) {
    console.error(e);
}
---

<Layout title="Generate Key - Zall">
    <main class="generate-container">
        <div class="glass-card main-card fade-in">
            <div class="text-center mb-4">
                <div class="icon-wrapper">
                    <i class="bi bi-key-fill"></i>
                </div>
                <h1 class="page-title">Generate Akses Key</h1>
                <p class="text-muted">
                    Pilih salah satu server di bawah untuk mendapatkan akses key
                    3 hari. Anda akan diarahkan untuk verifikasi singkat
                    terlebih dahulu.
                </p>
            </div>

            <div class="server-list">
                {
                    servers.map((server, index) => (
                        <button class="server-btn" data-id={server.id}>
                            <div class="server-icon outline-icon">
                                <i class="bi bi-cloud-arrow-down" />
                            </div>
                            <div class="server-info">
                                <h3>{server.label}</h3>
                                <span>Klik untuk akses via server ini</span>
                            </div>
                            <i class="bi bi-chevron-right text-muted action-icon" />
                        </button>
                    ))
                }

                {
                    servers.length === 0 && (
                        <div class="empty-state">
                            <i class="bi bi-info-circle text-muted text-2xl" />
                            <p>
                                Belum ada server yang tersedia saat ini. Silakan
                                coba lagi nanti.
                            </p>
                        </div>
                    )
                }
            </div>

            <div class="instructions mt-4 pt-4 border-top">
                <h4 class="instructions-title">
                    <i class="bi bi-journal-text me-2"></i> Cara Kerja:
                </h4>
                <ol class="steps-list">
                    <li>Pilih salah satu server yang tersedia di atas.</li>
                    <li>Selesaikan proses verifikasi keamanan (Shortlink).</li>
                    <li>
                        Anda akan otomatis diarahkan kembali ke sini beserta
                        Username dan Password Anda.
                    </li>
                </ol>
            </div>
        </div>
    </main>
</Layout>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="spinner-container">
        <div class="modern-spinner"></div>
        <p class="loading-title">Menghubungkan...</p>
        <p class="loading-subtitle" id="loadingText">
            Menyiapkan sesi aman Anda
        </p>
    </div>
</div>

<style>
    .generate-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        position: relative;
        z-index: 1;
    }

    .main-card {
        width: 100%;
        max-width: 480px;
        padding: 48px 40px;
    }

    .text-center {
        text-align: center;
    }
    .mb-4 {
        margin-bottom: 2rem;
    }
    .mt-4 {
        margin-top: 2rem;
    }
    .pt-4 {
        padding-top: 2rem;
    }
    .me-2 {
        margin-right: 0.5rem;
    }

    .icon-wrapper {
        width: 64px;
        height: 64px;
        margin: 0 auto 24px;
        border-radius: 16px;
        background: rgba(129, 140, 248, 0.1);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.8rem;
        color: var(--primary);
        border: 1px solid rgba(129, 140, 248, 0.2);
    }

    .page-title {
        font-size: 1.7rem;
        font-weight: 700;
        margin-bottom: 12px;
        color: var(--text-main);
        letter-spacing: -0.5px;
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .server-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 36px;
    }

    .server-btn {
        display: flex;
        align-items: center;
        gap: 16px;
        width: 100%;
        padding: 18px 20px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--card-border);
        border-radius: 14px;
        color: var(--text-main);
        cursor: pointer;
        transition: all 0.25s ease;
        text-align: left;
    }

    .server-btn:hover {
        background: rgba(255, 255, 255, 0.06);
        transform: translateY(-2px);
        border-color: rgba(129, 140, 248, 0.3);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    .outline-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.3rem;
        color: var(--text-main);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .server-info {
        flex: 1;
    }

    .server-info h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0 0 4px 0;
        color: var(--text-main);
    }

    .server-info span {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .action-icon {
        transition: transform 0.2s;
        font-size: 1.1rem;
    }

    .server-btn:hover .action-icon {
        transform: translateX(4px);
        color: var(--primary) !important;
    }

    .empty-state {
        text-align: center;
        padding: 32px 20px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 14px;
        border: 1px dashed var(--card-border);
    }

    .empty-state p {
        margin-top: 12px;
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .border-top {
        border-top: 1px solid var(--card-border);
    }

    .instructions-title {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 12px;
        color: var(--text-main);
    }

    .steps-list {
        padding-left: 20px;
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .steps-list li {
        margin-bottom: 8px;
    }

    /* Loading Overlay */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 17, 26, 0.9);
        backdrop-filter: blur(12px);
        z-index: 1000;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .spinner-container {
        text-align: center;
        animation: fadeIn 0.4s ease;
    }

    .modern-spinner {
        width: 48px;
        height: 48px;
        margin: 0 auto 20px;
        border: 3px solid rgba(129, 140, 248, 0.1);
        border-radius: 50%;
        border-top-color: var(--primary);
        animation: spin 1s cubic-bezier(0.6, 0.2, 0.4, 0.8) infinite;
    }

    .loading-title {
        font-weight: 600;
        font-size: 1.1rem;
        color: var(--text-main);
        letter-spacing: 0.5px;
    }

    .loading-subtitle {
        margin-top: 6px;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    @keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    .fade-in {
        animation: fadeIn 0.6s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .d-none {
        display: none !important;
    }
</style>

<script>
    const buttons = document.querySelectorAll(".server-btn");
    const loadingOverlay = document.getElementById("loadingOverlay");
    const loadingText = document.getElementById("loadingText");

    buttons.forEach((btn) => {
        btn.addEventListener("click", async (e) => {
            const el = e.currentTarget as HTMLElement;
            const serverId = el.getAttribute("data-id");

            if (!serverId) return;

            // Show loading
            if (loadingOverlay) loadingOverlay.classList.remove("d-none");

            try {
                const res = await fetch("/api/generate-token", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ serverId }),
                });

                const data = await res.json();

                if (res.ok && data.redirectUrl) {
                    if (loadingText)
                        loadingText.textContent =
                            "Mengarahkan ke tautan aman...";

                    setTimeout(() => {
                        window.location.href = data.redirectUrl;
                    }, 800);
                } else {
                    throw new Error(data.error || "Terjadi kesalahan server");
                }
            } catch (err: any) {
                if (loadingOverlay) loadingOverlay.classList.add("d-none");
                alert("Gagal terhubung ke server: " + err.message);
            }
        });
    });
</script>
